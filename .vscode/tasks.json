{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "kill-dcp",
            "type": "shell",
            "command": "taskkill /F /IM dcp.exe 2>nul || exit 0",
            "windows": {
                "command": "taskkill /F /IM dcp.exe 2>nul || exit 0"
            }
        },
        {
            "label": "build-carproject",
            "type": "shell",
            "command": "dotnet build CarProject/CarProject/CarProject.csproj",
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-apphost",
            "type": "shell",
            "command": "dotnet build CarProject/CarProject.AppHost/CarProject.AppHost.csproj",
            "group": "build",
            "problemMatcher": "$msCompile"
        }
    ]
}
