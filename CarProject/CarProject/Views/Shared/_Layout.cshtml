<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoVibes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarProject.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">
                    <span class="brand-icon"><i class="bi bi-car-front-fill"></i></span>
                    <span style="display: flex; flex-direction: column;">
                        AutoVibes
                        <span class="brand-sub">Premium Showroom</span>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav mx-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Cars">Danh sách xe</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @{
                            var isLoggedIn = Context.Session.GetInt32("UserId").HasValue;
                            var userRole = Context.Session.GetString("UserRole");
                            var userName = Context.Session.GetString("UserName");
                        }
                            @if (isLoggedIn)
                            {
                                @if (userRole == "Admin")
                                {
                                    <a class="nav-link" asp-page="/Admin/Index" style="color: var(--accent); font-weight: 600;">
                                        <i class="bi bi-shield-lock-fill"></i> Admin
                                    </a>
                                }
                                else
                                {
                                    <a class="nav-link" asp-page="/Admin/Logs/Index" style="color: var(--bs-info);">
                                        <i class="bi bi-clock-history"></i> Log
                                    </a>
                                }
                                <span class="text-light small me-2"><i class="bi bi-person-fill"></i> @userName</span>
                                <a class="nav-link btn-nav-login" asp-page="/Account/Logout">
                                    <i class="bi bi-box-arrow-right"></i> Thoát
                                </a>
                            }
                        else
                        {
                            <a class="nav-link" asp-page="/Account/Register" style="color: var(--bs-info);">
                                <i class="bi bi-person-plus"></i> Đăng ký
                            </a>
                            <a class="nav-link btn-nav-login" asp-page="/Account/Login">
                                <i class="bi bi-person"></i> Đăng nhập
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="page-transition">
        @RenderBody()
    </main>

    <!-- Floating Contact Buttons -->
    <div class="contact-floating">
        <a href="#" class="btn-contact btn-messenger" title="Messenger">
            <i class="bi bi-messenger"></i>
            <span class="tooltip-text">Chat Messenger</span>
        </a>
        <a href="#" class="btn-contact btn-zalo" title="Zalo">
            <i class="bi bi-chat-dots-fill"></i>
            <span class="tooltip-text">Chat Zalo</span>
        </a>
        <a href="tel:1900xxxx" class="btn-contact btn-phone" title="Gọi ngay">
            <i class="bi bi-telephone-fill"></i>
            <span class="tooltip-text">1900 xxxx</span>
        </a>
    </div>

    <footer class="footer-premium">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <a class="footer-brand" asp-page="/Index">
                        <span class="icon"><i class="bi bi-car-front-fill"></i></span>
                        AutoVibes
                    </a>
                    <p>Hệ thống phân phối ô tô cao cấp hàng đầu Việt Nam. Cam kết mang đến những sản phẩm đẳng cấp và dịch vụ tốt nhất cho khách hàng.</p>
                    <div class="social-links">
                        <a href="#" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" title="Zalo"><i class="bi bi-chat-dots-fill"></i></a>
                        <a href="#" title="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" title="Instagram"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-2">
                    <h6>Khám phá</h6>
                    <p><a asp-page="/Index">Trang chủ</a></p>
                    <p><a asp-page="/Cars">Danh sách xe</a></p>
                    <p><a asp-page="/Account/Login">Đăng nhập</a></p>
                </div>
                <div class="col-lg-3">
                    <h6>Liên hệ</h6>
                    <p><i class="bi bi-telephone-fill me-2"></i>1900 xxxx</p>
                    <p><i class="bi bi-envelope-fill me-2"></i>info@autovibes.vn</p>
                    <p><i class="bi bi-geo-alt-fill me-2"></i>123 Nguyễn Văn Linh, Hà Nội</p>
                </div>
                <div class="col-lg-3">
                    <h6>Giờ làm việc</h6>
                    <p>Thứ 2 - Thứ 7: 8:00 - 18:00</p>
                    <p>Chủ nhật: 8:00 - 12:00</p>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; 2026 AutoVibes Premium Showroom. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
