<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarProject.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
    @{
        var userName = User.GetJwtDisplayName() ?? User.GetJwtUserName() ?? "Admin";
        var avatarUrl = User.GetJwtAvatar();
    }

    <div class="admin-wrapper">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a asp-page="/Admin/Index" class="sidebar-brand">
                    <img src="~/uploads/Logo/LogoTrenChu.png" alt="MyLxCar" style="height: 28px; width: auto;" />
                </a>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">Tổng quan</div>
                <a asp-page="/Admin/Index" class="nav-item"><i class="fas fa-chart-pie"></i> Dashboard</a>

                <div class="nav-section">Quản lý xe</div>
                <a asp-page="/Admin/HangXe/Index" class="nav-item"><i class="fas fa-car"></i> Hãng xe</a>
                <a asp-page="/Admin/DongXe/Index" class="nav-item"><i class="fas fa-car-side"></i> Dòng xe</a>
                <a asp-page="/Admin/PhienBan/Index" class="nav-item"><i class="fas fa-tag"></i> Phiên bản</a>

                <div class="nav-section">Khách hàng</div>
                <a asp-page="/Admin/Users/Index" class="nav-item"><i class="fas fa-users"></i> Người dùng</a>
                <a asp-page="/Admin/DonCoc/Index" class="nav-item"><i class="fas fa-file-invoice"></i> Đơn cọc</a>
                <a asp-page="/Admin/LichHen/Index" class="nav-item"><i class="fas fa-calendar-alt"></i> Lịch hẹn</a>

                <div class="nav-section">Tài chính</div>
                <a asp-page="/Admin/HoaDon/Index" class="nav-item"><i class="fas fa-file-invoice-dollar"></i> Hóa đơn</a>
                <a asp-page="/Admin/ThongKe/DoanhThu" class="nav-item"><i class="fas fa-chart-line"></i> Doanh thu</a>
                <a asp-page="/Admin/ThongKe/Index" class="nav-item"><i class="fas fa-chart-bar"></i> Thống kê</a>

                <div class="nav-section">Hệ thống</div>
                <a asp-page="/Admin/ChiNhanh/Index" class="nav-item"><i class="fas fa-building"></i> Chi nhánh</a>
                <a asp-page="/Admin/KhuyenMai/Index" class="nav-item"><i class="fas fa-gift"></i> Khuyến mãi</a>
                <a asp-page="/Admin/Banner/Index" class="nav-item"><i class="fas fa-image"></i> Banner</a>
                <a asp-page="/Admin/KenhTuVan/Index" class="nav-item"><i class="fas fa-headset"></i> Kênh tư vấn</a>
                <a asp-page="/Admin/Logs/Index" class="nav-item"><i class="fas fa-history"></i> Nhật ký</a>
                <a asp-page="/Admin/Profile" class="nav-item"><i class="fas fa-user-cog"></i> Hồ sơ của tôi</a>
            </nav>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div style="width: 28px; height: 28px; border-radius: 50%; overflow: hidden; background: var(--brand-light-gray); flex-shrink: 0;">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <i class="fas fa-user" style="font-size: 0.7rem; color: var(--brand-silver); display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;"></i>
                        }
                    </div>
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--brand-white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@userName</div>
                        <div style="font-size: 0.6rem; color: rgba(255,255,255,0.35);">Admin</div>
                    </div>
                </div>
                <a asp-page="/Admin/ToggleMode" asp-route-mode="View" asp-route-returnUrl="/" class="sidebar-toggle-mode">
                    <i class="fas fa-eye me-2"></i> Xem giao diện
                </a>
                <a asp-page="/Account/Logout" class="sidebar-logout">
                    <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                </a>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <button class="sidebar-hamburger" id="sidebarToggle" type="button">
                    <i class="fas fa-bars"></i>
                </button>
                <a asp-page="/Admin/Index" class="admin-topbar-back">
                    <i class="fas fa-arrow-left"></i> Về Dashboard
                </a>
                <div class="admin-topbar-title">@ViewData["Title"]</div>
                <div class="admin-topbar-right">
                    <a asp-page="/Admin/ToggleMode" asp-route-mode="View" asp-route-returnUrl="/" class="btn-topbar" title="Xem giao diện người dùng">
                        <i class="fas fa-eye"></i>
                    </a>
                </div>
            </header>

            <div class="admin-content">
                @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
                {
                    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
                {
                    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            document.getElementById('adminSidebar').classList.toggle('sidebar-open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
