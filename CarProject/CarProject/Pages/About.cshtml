@page
@model AboutModel

@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="about-page">
    <!-- Hero -->
    <div class="about-hero reveal">
        <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(192,192,192,0.04) 0%, transparent 60%); pointer-events: none;"></div>
        <div class="container position-relative">
            <p class="section-label justify-content-center" style="margin-bottom: 1.5rem;">Thương hiệu Việt</p>
            <h1>MyCar</h1>
            <p>Kiến tạo những kiệt tác xe hơi sang trọng hàng đầu Việt Nam</p>
        </div>
    </div>

    <!-- History -->
    <section class="section-premium reveal">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="glass-card p-5">
                        <p class="section-label">Giới thiệu</p>
                        <h2 class="section-heading" style="font-size: 2rem;">Hành trình vươn tầm</h2>
                        <div class="text-muted-about" style="font-size: 0.9rem; line-height: 1.9;">
                            <p>MyCar là thương hiệu xe hơi hạng sang có trụ sở tại Việt Nam. Được thành lập vào năm 2024, thương hiệu này đã nhanh chóng trở thành biểu tượng của sự đổi mới, chất lượng và đẳng cấp trong ngành công nghiệp ô tô toàn cầu.</p>
                            <p>Với phương châm "Đẳng cấp vượt thời gian", MyCar luôn đặt tiêu chuẩn cao nhất trong từng chi tiết thiết kế và chế tạo. Từ những dòng xe sedan hạng sang cho đến những mẫu SUV mạnh mẽ, mỗi chiếc xe đều là một tuyên ngôn về phong cách và địa vị.</p>
                            <p>Tại Việt Nam, chúng tôi tự hào là đại lý ủy quyền chính thức của MyCar, cam kết mang đến cho khách hàng những sản phẩm và dịch vụ tốt nhất.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="section-premium section-premium-alt reveal">
        <div class="container">
            <div class="about-stats-grid">
                <div class="about-stat-card">
                    <div class="num">130+</div>
                    <div class="label">Năm lịch sử</div>
                </div>
                <div class="about-stat-card">
                    <div class="num">500+</div>
                    <div class="label">Kỹ sư & nghệ nhân</div>
                </div>
                <div class="about-stat-card">
                    <div class="num">50+</div>
                    <div class="label">Quốc gia</div>
                </div>
                <div class="about-stat-card">
                    <div class="num">490</div>
                    <div class="label">km/h tốc độ tối đa</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values -->
    <section class="section-premium reveal">
        <div class="container">
            <div class="text-center mb-5">
                <p class="section-label justify-content-center">Giá trị cốt lõi</p>
                <h2 class="section-heading text-center">Triết lý của chúng tôi</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="why-item">
                        <div class="icon"><i class="fas fa-palette"></i></div>
                        <h5>Nghệ thuật</h5>
                        <p>Mỗi đường nét thiết kế là một tác phẩm nghệ thuật, kết hợp giữa truyền thống và hiện đại.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="why-item">
                        <div class="icon"><i class="fas fa-microchip"></i></div>
                        <h5>Kỹ thuật</h5>
                        <p>Công nghệ tiên phong với những đột phá về an toàn, hiệu suất và tiện nghi.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="why-item">
                        <div class="icon"><i class="fas fa-hand-sparkles"></i></div>
                        <h5>Thủ công</h5>
                        <p>Chế tác thủ công tinh xảo bởi những nghệ nhân giàu kinh nghiệm nhất.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
