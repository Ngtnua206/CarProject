@page "{id}"
@model CarProject.Pages.Admin.HoaDon.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Hóa Đơn</h2>
            @if (Model.HoaDon == null)
            {
                <div class="alert alert-danger">Không tìm thấy hóa đơn.</div>
            }
            else
            {
                <div class="alert alert-warning">
                    <p>Bạn có chắc muốn xóa hóa đơn <strong>@Model.HoaDon.MaHoaDon</strong>?</p>
                    <ul>
                        <li>Tổng tiền: <strong>@Model.HoaDon.TongTienPhaiTra.ToString("N0")</strong></li>
                        <li>Trạng thái: <strong>@Model.HoaDon.TrangThaiHoaDon</strong></li>
                    </ul>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="HoaDon.MaHoaDon" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
