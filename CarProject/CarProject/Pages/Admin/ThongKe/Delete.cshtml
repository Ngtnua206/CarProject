@page "{id:int}"
@model CarProject.Pages.Admin.ThongKe.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Thống Kê</h2>
            @if (Model.ThongKe == null)
            {
                <div class="alert alert-danger">Không tìm thấy thống kê.</div>
            }
            else
            {
                <div class="alert alert-warning">
                    <p>Bạn có chắc muốn xóa thống kê <strong>@Model.ThongKe.KyBaoCao</strong> (mã @Model.ThongKe.MaThongKe)?</p>
                    <ul>
                        <li>Doanh thu: <strong>@Model.ThongKe.TongDoanhThu.ToString("N0")</strong></li>
                        <li>Xe đã bán: <strong>@Model.ThongKe.TongSoXeDaBan</strong></li>
                    </ul>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="ThongKe.MaThongKe" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
