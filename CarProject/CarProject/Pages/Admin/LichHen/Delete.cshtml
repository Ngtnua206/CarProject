@page "{id:int}"
@model CarProject.Pages.Admin.LichHen.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Lịch Hẹn Lái Thử</h2>
            @if (Model.LichHen == null)
            {
                <div class="alert alert-danger">Không tìm thấy lịch hẹn.</div>
            }
            else
            {
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa lịch hẹn <strong>#@Model.LichHen.MaLichHen</strong>?
                    <br />Khách hàng: <strong>@Model.LichHen.KhachHang?.TenDangNhap</strong>
                    <br />Dòng xe: <strong>@Model.LichHen.DongXe?.TenDong</strong>
                    <br />Chi nhánh: <strong>@Model.LichHen.ChiNhanh?.TenChiNhanh</strong>
                    <br />Ngày hẹn: <strong>@Model.LichHen.NgayHen.ToString("dd/MM/yyyy")</strong>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="LichHen.MaLichHen" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
