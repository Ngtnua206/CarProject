@page "{id:int}"
@model CarProject.Pages.Admin.Banner.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Banner Quảng Cáo</h2>
            @if (Model.Banner == null)
            {
                <div class="alert alert-danger">Không tìm thấy banner.</div>
            }
            else
            {
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa banner <strong>@Model.Banner.DuongDanAnh</strong>?
                </div>
                <dl class="row">
                    <dt class="col-sm-4">Đường dẫn liên kết</dt>
                    <dd class="col-sm-8">@Model.Banner.DuongDanLienKet</dd>
                    <dt class="col-sm-4">Thứ tự hiển thị</dt>
                    <dd class="col-sm-8">@Model.Banner.ThuTuHienThi</dd>
                    <dt class="col-sm-4">Kích hoạt</dt>
                    <dd class="col-sm-8">@(Model.Banner.TrangThaiKichHoat ? "Có" : "Không")</dd>
                </dl>
                <form method="post">
                    <input type="hidden" asp-for="Banner.MaBanner" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
