@page
@model CarProject.Pages.Admin.Banner.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Quảng Cáo Banner</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Banner</a>
            </div>

            @if (Model.BannerList.Count == 0)
            {
                <div class="alert alert-info">Không có banner nào.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Ảnh</th>
                                <th>Liên Kết</th>
                                <th>Thứ Tự</th>
                                <th>Kích Hoạt</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.BannerList)
                            {
                                <tr>
                                    <td>@b.MaBanner</td>
                                    <td>@b.DuongDanAnh</td>
                                    <td>@b.DuongDanLienKet</td>
                                    <td>@b.ThuTuHienThi</td>
                                    <td>
                                        <span class="badge @(b.TrangThaiKichHoat ? "bg-success" : "bg-danger")">
                                            @(b.TrangThaiKichHoat ? "Có" : "Không")
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-page="Edit" asp-route-id="@b.MaBanner" class="btn btn-sm btn-warning">Sửa</a>
                                        <a asp-page="Delete" asp-route-id="@b.MaBanner" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
