@page
@model CarProject.Pages.Admin.ChiNhanh.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Chi Nhánh Showroom</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Chi Nhánh</a>
            </div>

            @if (Model.ChiNhanhList.Count == 0)
            {
                <div class="alert alert-info">Không có chi nhánh nào.</div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã CN</th>
                            <th>Tên Chi Nhánh</th>
                            <th>Địa Chỉ</th>
                            <th>Thành Phố</th>
                            <th>Đường Dây Nóng</th>
                            <th>Quản Lý</th>
                            <th>Trạng Thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cn in Model.ChiNhanhList)
                        {
                            <tr>
                                <td>@cn.MaChiNhanh</td>
                                <td>@cn.TenChiNhanh</td>
                                <td>@cn.DiaChi</td>
                                <td>@cn.ThanhPho</td>
                                <td>@cn.DuongDayNong</td>
                                <td>@cn.QuanLy?.TenDangNhap</td>
                                <td>@cn.TrangThai</td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@cn.MaChiNhanh" class="btn btn-sm btn-warning">Sửa</a>
                                    <a asp-page="Delete" asp-route-id="@cn.MaChiNhanh" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
