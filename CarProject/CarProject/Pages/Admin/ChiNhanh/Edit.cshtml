@page "{id}"
@model CarProject.Pages.Admin.ChiNhanh.EditModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Sửa Chi Nhánh</h2>
            @if (Model.ChiNhanh == null)
            {
                <div class="alert alert-danger">Không tìm thấy chi nhánh.</div>
            }
            else
            {
                <form method="post">
                    <input type="hidden" asp-for="ChiNhanh.MaChiNhanh" />
                    <div class="mb-3">
                        <label class="form-label">Mã Chi Nhánh</label>
                        <input class="form-control" value="@Model.ChiNhanh.MaChiNhanh" disabled />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ChiNhanh.TenChiNhanh" class="form-label">Tên Chi Nhánh</label>
                        <input asp-for="ChiNhanh.TenChiNhanh" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ChiNhanh.DiaChi" class="form-label">Địa Chỉ</label>
                        <input asp-for="ChiNhanh.DiaChi" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ChiNhanh.ThanhPho" class="form-label">Thành Phố</label>
                        <input asp-for="ChiNhanh.ThanhPho" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ChiNhanh.DuongDayNong" class="form-label">Đường Dây Nóng</label>
                        <input asp-for="ChiNhanh.DuongDayNong" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ChiNhanh.MaQuanLy" class="form-label">Quản Lý</label>
                        <select asp-for="ChiNhanh.MaQuanLy" asp-items="Model.QuanLyList" class="form-select" required>
                            <option value="">-- Chọn quản lý --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ChiNhanh.TrangThai" class="form-label">Trạng Thái</label>
                        <select asp-for="ChiNhanh.TrangThai" class="form-select" required>
                            <option value="Hoạt động">Hoạt động</option>
                            <option value="Ngừng hoạt động">Ngừng hoạt động</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">Cập nhật</button>
                        <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
