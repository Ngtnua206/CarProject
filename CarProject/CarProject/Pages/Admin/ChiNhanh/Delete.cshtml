@page "{id}"
@model CarProject.Pages.Admin.ChiNhanh.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Chi Nhánh</h2>
            @if (Model.ChiNhanh == null)
            {
                <div class="alert alert-danger">Không tìm thấy chi nhánh.</div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa chi nhánh <strong>@Model.ChiNhanh.TenChiNhanh</strong> (Mã: @Model.ChiNhanh.MaChiNhanh)?
                </div>
                <form method="post">
                    <input type="hidden" asp-for="ChiNhanh.MaChiNhanh" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
