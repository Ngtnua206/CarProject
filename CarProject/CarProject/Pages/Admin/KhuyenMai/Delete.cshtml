@page "{id}"
@model CarProject.Pages.Admin.KhuyenMai.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Khuyến Mãi</h2>
            @if (Model.KhuyenMai == null)
            {
                <div class="alert alert-danger">Không tìm thấy khuyến mãi.</div>
            }
            else
            {
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa khuyến mãi <strong>@Model.KhuyenMai.TieuDe</strong> (Mã: @Model.KhuyenMai.MaKhuyenMai)?
                </div>
                <form method="post">
                    <input type="hidden" asp-for="KhuyenMai.MaKhuyenMai" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
