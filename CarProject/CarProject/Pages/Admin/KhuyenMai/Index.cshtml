@page
@model CarProject.Pages.Admin.KhuyenMai.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Khuyến Mãi</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Khuyến Mãi</a>
            </div>

            @if (Model.KhuyenMaiList.Count == 0)
            {
                <div class="alert alert-info">Không có khuyến mãi nào.</div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã KM</th>
                            <th>Tiêu Đề</th>
                            <th>Loại Giảm</th>
                            <th>Giá Trị</th>
                            <th>Thời Gian</th>
                            <th>Trạng Thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var km in Model.KhuyenMaiList)
                        {
                            <tr>
                                <td>@km.MaKhuyenMai</td>
                                <td>@km.TieuDe</td>
                                <td>@km.LoaiGiamGia</td>
                                <td>@km.GiaTriGiam</td>
                                <td>@km.NgayBatDau.ToString("dd/MM/yyyy") - @km.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                <td>@km.TrangThai</td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@km.MaKhuyenMai" class="btn btn-sm btn-warning">Sửa</a>
                                    <a asp-page="Delete" asp-route-id="@km.MaKhuyenMai" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
