@page
@model CarProject.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-people-fill"></i> Quản lý người dùng</h2>

    <div class="table-responsive">
        <table class="table table-sm table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên đăng nhập</th>
                    <th>Tên hiển thị</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Chi nhánh</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    var showroomName = Model.UserShowroomMap.GetValueOrDefault(user.TenDangNhap);
                    <tr class="@(user.TrangThai == "Banned" ? "bg-danger" : "")">
                        <td>@user.MaTaiKhoan</td>
                        <td>@user.TenDangNhap</td>
                        <td>@(user.TenHienThi ?? "—")</td>
                        <td>@(user.Email ?? "—")</td>
                        <td>
                            <span class="badge bg-@(user.VaiTro == "Admin" ? "danger" : user.VaiTro == "Quản Lý" ? "warning" : "secondary")">
                                @user.VaiTro
                            </span>
                        </td>
                        <td>
                            @if (user.VaiTro == "Quản Lý")
                            {
                                <form method="post" asp-page-handler="AssignShowroom" style="display:inline">
                                    <input type="hidden" name="tenDangNhap" value="@user.TenDangNhap" />
                                    <select name="maChiNhanh" class="form-select form-select-sm d-inline w-auto" onchange="this.form.submit()" style="font-size:0.75rem;">
                                        <option value="">— Chưa phân —</option>
                                        @foreach (var cn in Model.DanhSachChiNhanh)
                                        {
                                            <option value="@cn.MaChiNhanh" selected="@(showroomName == cn.TenChiNhanh)">
                                                @cn.TenChiNhanh
                                            </option>
                                        }
                                    </select>
                                </form>
                            }
                            else if (showroomName != null)
                            {
                                <span class="text-muted small">@showroomName</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (user.TrangThai == "Banned")
                            {
                                <span class="badge bg-danger">Bị khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                @if (user.VaiTro != "Admin")
                                {
                                    <form method="post" asp-page-handler="UpdateRole" style="display:inline">
                                        <input type="hidden" name="tenDangNhap" value="@user.TenDangNhap" />
                                        <select name="vaiTroMoi" class="form-select form-select-sm d-inline w-auto" onchange="this.form.submit()" style="font-size:0.75rem;">
                                            <option value="User" selected="@(user.VaiTro == "User")">User</option>
                                            <option value="Quản Lý" selected="@(user.VaiTro == "Quản Lý")">Quản Lý</option>
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Admin</span>
                                }

                                @if (user.VaiTro != "Admin")
                                {
                                    if (user.TrangThai == "Banned")
                                    {
                                        <form method="post" asp-page-handler="Unban" style="display:inline">
                                            <input type="hidden" name="tenDangNhap" value="@user.TenDangNhap" />
                                            <button type="submit" class="btn btn-success btn-sm">Mở khóa</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Ban" style="display:inline">
                                            <input type="hidden" name="tenDangNhap" value="@user.TenDangNhap" />
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Khóa tài khoản @user.TenDangNhap?')">Khóa</button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="Delete" style="display:inline">
                                        <input type="hidden" name="tenDangNhap" value="@user.TenDangNhap" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Xóa HOÀN TOÀN tài khoản @user.TenDangNhap?\nTất cả dữ liệu liên quan (nhật ký, đơn cọc, lịch hẹn, banner) cũng sẽ bị xóa.\nHành động này KHÔNG THỂ hoàn tác!')">Xóa</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-2">
        <a asp-page="/Admin/Index" class="btn btn-outline-secondary btn-sm">← Về Dashboard</a>
    </div>
</div>
