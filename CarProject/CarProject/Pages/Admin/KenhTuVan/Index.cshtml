@page
@model CarProject.Pages.Admin.KenhTuVan.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Kênh Tư Vấn</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Kênh</a>
            </div>

            @if (Model.KenhList.Count == 0)
            {
                <div class="alert alert-info">Không có kênh tư vấn nào.</div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã Kênh</th>
                            <th>URL Messenger</th>
                            <th>URL Zalo</th>
                            <th>URL SMS</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var k in Model.KenhList)
                        {
                            <tr>
                                <td>@k.MaKenh</td>
                                <td>@k.UrlMessenger</td>
                                <td>@k.UrlZalo</td>
                                <td>@k.UrlSMS</td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@k.MaKenh" class="btn btn-sm btn-warning">Sửa</a>
                                    <a asp-page="Delete" asp-route-id="@k.MaKenh" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
