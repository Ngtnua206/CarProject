@page
@model CarProject.Pages.Admin.HangXe.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Hãng Xe</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Hãng Xe</a>
            </div>

            @if (Model.HangXeList.Count == 0)
            {
                <div class="alert alert-info">Không có hãng xe nào.</div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã Hãng</th>
                            <th>Tên Hãng</th>
                            <th>Quốc Gia</th>
                            <th>Logo</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hang in Model.HangXeList)
                        {
                            <tr>
                                <td>@hang.MaHang</td>
                                <td>@hang.TenHang</td>
                                <td>@hang.QuocGia</td>
                                <td>@hang.DuongDanLogo</td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@hang.MaHang" class="btn btn-sm btn-warning">Sửa</a>
                                    <a asp-page="Delete" asp-route-id="@hang.MaHang" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
