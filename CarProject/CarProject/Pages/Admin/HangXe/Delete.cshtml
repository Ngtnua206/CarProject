@page "{id:int}"
@model CarProject.Pages.Admin.HangXe.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Hãng Xe</h2>
            @if (Model.HangXe == null)
            {
                <div class="alert alert-danger">Không tìm thấy hãng xe.</div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa hãng xe <strong>@Model.HangXe.TenHang</strong>?
                </div>
                <form method="post">
                    <input type="hidden" asp-for="HangXe.MaHang" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
