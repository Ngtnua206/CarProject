@page "{id:int}"
@model CarProject.Pages.Admin.HangXe.EditModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Sửa Hãng Xe</h2>
            @if (Model.HangXe == null)
            {
                <div class="alert alert-danger">Không tìm thấy hãng xe.</div>
            }
            else
            {
                <form method="post">
                    <input type="hidden" asp-for="HangXe.MaHang" />
                    <div class="mb-3">
                        <label asp-for="HangXe.TenHang" class="form-label">Tên Hãng</label>
                        <input asp-for="HangXe.TenHang" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="HangXe.QuocGia" class="form-label">Quốc Gia</label>
                        <input asp-for="HangXe.QuocGia" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="HangXe.DuongDanLogo" class="form-label">Đường dẫn Logo</label>
                        <input asp-for="HangXe.DuongDanLogo" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">Cập nhật</button>
                        <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
