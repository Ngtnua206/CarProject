@page
@model CarProject.Pages.Admin.PhienBan.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Phiên Bản Xe</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Phiên Bản</a>
            </div>

            @if (Model.PhienBanList.Count == 0)
            {
                <div class="alert alert-info">Không có phiên bản xe nào.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-sm">
                        <thead>
                            <tr>
                                <th>Mã PB</th>
                                <th>Tên Phiên Bản</th>
                                <th>Dòng Xe</th>
                                <th>Giá (VNĐ)</th>
                                <th>Màu</th>
                                <th>Kho</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pb in Model.PhienBanList)
                            {
                                <tr>
                                    <td>@pb.MaPhienBan</td>
                                    <td>@pb.TenPhienBan</td>
                                    <td>@pb.DongXe?.TenDong</td>
                                    <td>@pb.GiaNiemYet.ToString("N0")</td>
                                    <td>@pb.MauSac</td>
                                    <td>@pb.SoLuongTrongKho</td>
                                    <td>
                                        <a asp-page="Edit" asp-route-id="@pb.MaPhienBan" class="btn btn-sm btn-warning">Sửa</a>
                                        <a asp-page="Delete" asp-route-id="@pb.MaPhienBan" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
