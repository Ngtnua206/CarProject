@page "{id:int}"
@model CarProject.Pages.Admin.DonCoc.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Đơn Cọc</h2>
            @if (Model.DonCoc == null)
            {
                <div class="alert alert-danger">Không tìm thấy đơn cọc.</div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa đơn cọc <strong>#@Model.DonCoc.MaDonCoc</strong>?
                    <br />Số tiền: <strong>@Model.DonCoc.SoTienCoc.ToString("N0")</strong>
                    <br />Trạng thái: <strong>@Model.DonCoc.TrangThaiDonHang</strong>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="DonCoc.MaDonCoc" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
