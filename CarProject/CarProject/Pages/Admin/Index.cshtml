@page
@model CarProject.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-bg-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Hãng Xe</h5>
                    <p class="display-6 fw-bold">@Model.TotalHangXe</p>
                    <a asp-page="/Admin/HangXe/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Dòng Xe</h5>
                    <p class="display-6 fw-bold">@Model.TotalDongXe</p>
                    <a asp-page="/Admin/DongXe/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-warning h-100">
                <div class="card-body">
                    <h5 class="card-title">Phiên bản</h5>
                    <p class="display-6 fw-bold">@Model.TotalPhienBan</p>
                    <a asp-page="/Admin/PhienBan/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-info h-100">
                <div class="card-body">
                    <h5 class="card-title">Banner</h5>
                    <p class="display-6 fw-bold">@Model.TotalBanner</p>
                    <a asp-page="/Admin/Banner/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-secondary h-100">
                <div class="card-body">
                    <h5 class="card-title">Nhật ký</h5>
                    <p class="display-6 fw-bold">@Model.TotalLogs</p>
                    <a asp-page="/Admin/Logs/Index" class="text-white stretched-link text-decoration-none">Xem →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-dark h-100">
                <div class="card-body">
                    <h5 class="card-title">Người dùng</h5>
                    <p class="display-6 fw-bold">@Model.TotalUsers</p>
                    <a asp-page="/Admin/Users/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-danger h-100">
                <div class="card-body">
                    <h5 class="card-title">Chi nhánh</h5>
                    <p class="display-6 fw-bold">@Model.TotalChiNhanh</p>
                    <a asp-page="/Admin/ChiNhanh/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Khuyến mãi</h5>
                    <p class="display-6 fw-bold">@Model.TotalKhuyenMai</p>
                    <a asp-page="/Admin/KhuyenMai/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Đơn cọc</h5>
                    <p class="display-6 fw-bold">@Model.TotalDonCoc</p>
                    <a asp-page="/Admin/DonCoc/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-warning h-100">
                <div class="card-body">
                    <h5 class="card-title">Hóa đơn</h5>
                    <p class="display-6 fw-bold">@Model.TotalHoaDon</p>
                    <a asp-page="/Admin/HoaDon/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-info h-100">
                <div class="card-body">
                    <h5 class="card-title">Lịch hẹn</h5>
                    <p class="display-6 fw-bold">@Model.TotalLichHen</p>
                    <a asp-page="/Admin/LichHen/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-secondary h-100">
                <div class="card-body">
                    <h5 class="card-title">Kênh tư vấn</h5>
                    <p class="display-6 fw-bold">@Model.TotalKenhTuVan</p>
                    <a asp-page="/Admin/KenhTuVan/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-dark h-100">
                <div class="card-body">
                    <h5 class="card-title">Thống kê</h5>
                    <p class="display-6 fw-bold">@Model.TotalThongKe</p>
                    <a asp-page="/Admin/ThongKe/Index" class="text-white stretched-link text-decoration-none">Quản lý →</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Quản lý nhanh</h5>
        </div>
        <div class="list-group list-group-flush">
            <a asp-page="/Admin/HangXe/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Hãng Xe
                <span class="badge bg-primary rounded-pill">@Model.TotalHangXe</span>
            </a>
            <a asp-page="/Admin/DongXe/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Dòng Xe
                <span class="badge bg-success rounded-pill">@Model.TotalDongXe</span>
            </a>
            <a asp-page="/Admin/PhienBan/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Phiên bản Xe
                <span class="badge bg-warning rounded-pill">@Model.TotalPhienBan</span>
            </a>
            <a asp-page="/Admin/Banner/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Banner
                <span class="badge bg-info rounded-pill">@Model.TotalBanner</span>
            </a>
            <a asp-page="/Admin/Logs/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Nhật ký hoạt động
                <span class="badge bg-secondary rounded-pill">@Model.TotalLogs</span>
            </a>
            <a asp-page="/Admin/Users/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý người dùng
                <span class="badge bg-dark rounded-pill">@Model.TotalUsers</span>
            </a>
            <a asp-page="/Admin/ChiNhanh/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Chi nhánh
                <span class="badge bg-danger rounded-pill">@Model.TotalChiNhanh</span>
            </a>
            <a asp-page="/Admin/KhuyenMai/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Khuyến mãi
                <span class="badge bg-primary rounded-pill">@Model.TotalKhuyenMai</span>
            </a>
            <a asp-page="/Admin/DonCoc/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Đơn cọc
                <span class="badge bg-success rounded-pill">@Model.TotalDonCoc</span>
            </a>
            <a asp-page="/Admin/HoaDon/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Hóa đơn
                <span class="badge bg-warning rounded-pill">@Model.TotalHoaDon</span>
            </a>
            <a asp-page="/Admin/LichHen/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Lịch hẹn
                <span class="badge bg-info rounded-pill">@Model.TotalLichHen</span>
            </a>
            <a asp-page="/Admin/KenhTuVan/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Kênh tư vấn
                <span class="badge bg-secondary rounded-pill">@Model.TotalKenhTuVan</span>
            </a>
            <a asp-page="/Admin/ThongKe/Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Quản lý Thống kê
                <span class="badge bg-dark rounded-pill">@Model.TotalThongKe</span>
            </a>
            <a asp-page="/Index" class="list-group-item list-group-item-action">
                ← Về trang chủ
            </a>
        </div>
    </div>

    <div class="mt-3">
        <p class="text-muted small">Xin chào, <strong>@HttpContext.Session.GetString("UserName")</strong> (@HttpContext.Session.GetString("UserRole"))</p>
        <a asp-page="/Account/Logout" class="btn btn-outline-danger btn-sm">Đăng xuất</a>
    </div>
</div>
