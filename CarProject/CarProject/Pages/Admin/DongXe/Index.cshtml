@page
@model CarProject.Pages.Admin.DongXe.IndexModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Quản lý Dòng Xe</h2>
                <a asp-page="Create" class="btn btn-primary">+ Thêm Dòng Xe</a>
            </div>

            @if (Model.DongXeList.Count == 0)
            {
                <div class="alert alert-info">Không có dòng xe nào.</div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã Dòng</th>
                            <th>Tên Dòng</th>
                            <th>Hãng</th>
                            <th>Kiểu Dáng</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dong in Model.DongXeList)
                        {
                            <tr>
                                <td>@dong.MaDong</td>
                                <td>@dong.TenDong</td>
                                <td>@dong.HangXe?.TenHang</td>
                                <td>@dong.KieuDang</td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@dong.MaDong" class="btn btn-sm btn-warning">Sửa</a>
                                    <a asp-page="Delete" asp-route-id="@dong.MaDong" class="btn btn-sm btn-danger" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
