@page "{id:int}"
@model CarProject.Pages.Admin.DongXe.DeleteModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h2>Xóa Dòng Xe</h2>
            @if (Model.DongXe == null)
            {
                <div class="alert alert-danger">Không tìm thấy dòng xe.</div>
            }
            else
            {
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa dòng xe <strong>@Model.DongXe.TenDong</strong>?
                </div>
                <form method="post">
                    <input type="hidden" asp-for="DongXe.MaDong" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            }
        </div>
    </div>
</div>
