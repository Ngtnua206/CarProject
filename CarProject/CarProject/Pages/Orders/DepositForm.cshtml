@page "{id:int}"
@model CarProject.Pages.Orders.DepositFormModel

@{
    ViewData["Title"] = "Đặt cọc xe";
}

<div class="section-premium">
    <div class="container">
        <nav class="breadcrumb-premium mb-4">
            <a asp-page="/Index"><i class="bi bi-house-fill"></i> Trang chủ</a>
            <span>/</span>
            <a asp-page="/Cars">Danh sách xe</a>
            <span>/</span>
            <a asp-page="/Details" asp-route-id="@Model.PhienBan?.MaDong">Chi tiết</a>
            <span>/</span>
            <span>Đặt cọc</span>
        </nav>

        @if (Model.PhienBan == null)
        {
            <div class="text-center py-5">
                <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;"><i class="bi bi-exclamation-triangle"></i></div>
                <h4>Không tìm thấy phiên bản xe</h4>
                <a asp-page="/Index" class="btn-primary-premium mt-3 d-inline-flex"><i class="bi bi-arrow-left"></i> Quay lại</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-lg-5">
                    <div style="background: var(--white); border: 1px solid var(--silver-2); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
                        <div style="background: var(--black); padding: 2rem; text-align: center;">
                            <i class="bi bi-car-front-fill" style="font-size: 4rem; color: rgba(255,255,255,0.1);"></i>
                        </div>
                        <div style="padding: 1.5rem;">
                            <h5 style="font-weight: 700; margin-bottom: 1rem;">@Model.PhienBan.TenPhienBan</h5>
                            <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; padding: 0.4rem 0; border-bottom: 1px solid var(--silver-2); font-size: 0.85rem;">
                                    <span style="color: var(--gray);">Dòng xe</span>
                                    <span style="font-weight: 600;">@Model.PhienBan.DongXe?.TenDong</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 0.4rem 0; border-bottom: 1px solid var(--silver-2); font-size: 0.85rem;">
                                    <span style="color: var(--gray);">Màu sắc</span>
                                    <span style="font-weight: 600;">@Model.PhienBan.MauSac</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 0.4rem 0; border-bottom: 1px solid var(--silver-2); font-size: 0.85rem;">
                                    <span style="color: var(--gray);">Động cơ</span>
                                    <span style="font-weight: 600;">@Model.PhienBan.DongCo</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 0.4rem 0; font-size: 0.85rem;">
                                    <span style="color: var(--gray);">Hộp số</span>
                                    <span style="font-weight: 600;">@Model.PhienBan.HopSo</span>
                                </div>
                            </div>
                            <div style="font-size: 1.5rem; font-weight: 800; color: var(--accent);">
                                @{
                                    var price = Model.PhienBan.GiaNiemYet >= 1_000_000_000
                                        ? $"{Model.PhienBan.GiaNiemYet / 1_000_000_000:N1} tỷ"
                                        : $"{Model.PhienBan.GiaNiemYet / 1_000_000:N0} triệu";
                                }
                                @price <small style="font-size: 0.78rem; font-weight: 400; color: var(--light-gray);">VNĐ</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div style="background: var(--white); border: 1px solid var(--silver-2); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-sm);">
                        <h4 style="font-weight: 800; margin-bottom: 0.5rem; font-family: var(--font-display);">Thông tin đặt cọc</h4>
                        <p style="color: var(--gray); font-size: 0.9rem; margin-bottom: 1.5rem;">Vui lòng điền đầy đủ thông tin bên dưới</p>

                        <form method="post">
                            <input type="hidden" asp-for="DepositData.MaPhienBan" value="@Model.PhienBan.MaPhienBan" />

                            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                            {
                                <div class="alert alert-success" style="border-radius: var(--radius-sm); font-size: 0.85rem; padding: 0.75rem 1rem;">@Model.SuccessMessage</div>
                            }

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="DepositData.HoTen" class="form-label" style="font-weight: 600; font-size: 0.85rem;">Họ tên</label>
                                    <input asp-for="DepositData.HoTen" class="form-control" required placeholder="Nhập họ tên" style="border-radius: var(--radius-sm); border-color: var(--silver-2); padding: 0.6rem 0.8rem;" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DepositData.SoDienThoai" class="form-label" style="font-weight: 600; font-size: 0.85rem;">Số điện thoại</label>
                                    <input asp-for="DepositData.SoDienThoai" class="form-control" required placeholder="Nhập số điện thoại" style="border-radius: var(--radius-sm); border-color: var(--silver-2); padding: 0.6rem 0.8rem;" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="DepositData.DiaChi" class="form-label" style="font-weight: 600; font-size: 0.85rem;">Địa chỉ</label>
                                    <input asp-for="DepositData.DiaChi" class="form-control" required placeholder="Nhập địa chỉ" style="border-radius: var(--radius-sm); border-color: var(--silver-2); padding: 0.6rem 0.8rem;" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DepositData.SoTienCoc" class="form-label" style="font-weight: 600; font-size: 0.85rem;">Số tiền cọc (VNĐ)</label>
                                    <input asp-for="DepositData.SoTienCoc" type="number" class="form-control" required placeholder="VD: 50,000,000" style="border-radius: var(--radius-sm); border-color: var(--silver-2); padding: 0.6rem 0.8rem;" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DepositData.PhuongThucThanhToan" class="form-label" style="font-weight: 600; font-size: 0.85rem;">Phương thức thanh toán</label>
                                    <select asp-for="DepositData.PhuongThucThanhToan" class="form-control" required style="border-radius: var(--radius-sm); border-color: var(--silver-2); padding: 0.6rem 0.8rem;">
                                        <option value="">-- Chọn phương thức --</option>
                                        <option value="Tiền mặt">Tiền mặt</option>
                                        <option value="Chuyển khoản">Chuyển khoản</option>
                                        <option value="Thẻ tín dụng">Thẻ tín dụng</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label asp-for="DepositData.GhiChu" class="form-label" style="font-weight: 600; font-size: 0.85rem;">Ghi chú</label>
                                    <textarea asp-for="DepositData.GhiChu" class="form-control" rows="3" placeholder="Nhập ghi chú nếu có..." style="border-radius: var(--radius-sm); border-color: var(--silver-2); padding: 0.6rem 0.8rem;"></textarea>
                                </div>
                            </div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn-primary-premium" style="flex: 1; justify-content: center; padding: 0.7rem;">
                                    <i class="bi bi-check-lg"></i> Xác nhận đặt cọc
                                </button>
                                <a asp-page="/Details" asp-route-id="@Model.PhienBan.MaDong" class="btn-outline-premium" style="flex: 0 0 auto; padding: 0.7rem 1.5rem;">
                                    Hủy
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
