@page
@model CarProject.Pages.Orders.Cart.CheckoutModel
@{
    ViewData["Title"] = "Xác nhận đặt cọc";
}

<div class="deposit-page">
    <div class="container py-4">
        <nav class="breadcrumb-premium mb-4">
            <a asp-page="/Index"><i class="fas fa-home"></i> Trang chủ</a>
            <span>/</span>
            <a asp-page="/Orders/Cart/Index">Giỏ hàng</a>
            <span>/</span>
            <span>Xác nhận</span>
        </nav>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="deposit-card">
                    <h4>Danh sách xe (@Model.CartItems.Count xe)</h4>
                    <div style="max-height: 400px; overflow-y: auto; margin-top: 1rem;">
                        @foreach (var item in Model.CartItems)
                        {
                            <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 0.8rem; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight: 600; color: var(--brand-white); font-size: 0.9rem;">
                                        @item.TenPhienBan
                                        <span style="font-weight:400;color: var(--text-faint);font-size:0.78rem;"> x @item.SoLuong</span>
                                    </div>
                                    <div style="font-size: 0.75rem; color: var(--text-faint);">@item.TenDong - @item.MauSac</div>
                                </div>
                                <div style="text-align:right;flex-shrink:0;">
                                    <div style="font-weight: 700; color: var(--brand-gold); font-size: 0.9rem;">
                                        @{
                                            var lineTotal = item.SoTienCoc * item.SoLuong;
                                        }
                                        @(lineTotal >= 1_000_000_000
                                            ? $"{lineTotal / 1_000_000_000:N1} tỷ"
                                            : $"{lineTotal / 1_000_000:N0} triệu")
                                    </div>
                                    <div style="font-size:0.68rem;color: var(--text-faint);">@item.SoTienCoc.ToString("N0")đ x @item.SoLuong</div>
                                </div>
                            </div>
                        }
                    </div>
                    <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Tổng tiền cọc</span>
                        <span style="font-weight: 700; color: var(--brand-gold); font-size: 1.2rem;">
                            @(Model.TotalDeposit >= 1_000_000_000
                                ? $"{Model.TotalDeposit / 1_000_000_000:N2} tỷ"
                                : $"{Model.TotalDeposit / 1_000_000:N0} triệu") VNĐ
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="deposit-card">
                    <h4>Thông tin người đặt</h4>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">Điền thông tin để hoàn tất đặt cọc</p>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div style="background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; padding: 0.75rem 1rem; font-size: 0.85rem; margin-bottom: 1.5rem;">
                            <i class="fas fa-exclamation-circle me-1"></i> @Model.ErrorMessage
                        </div>
                    }

                    <form method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ tên</label>
                                <input asp-for="HoTen" class="form-control" required placeholder="Nhập họ tên" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                <input asp-for="SoDienThoai" class="form-control" required placeholder="Nhập số điện thoại" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Địa chỉ</label>
                                <input asp-for="DiaChi" class="form-control" required placeholder="Nhập địa chỉ" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phương thức thanh toán</label>
                                <select asp-for="PhuongThucThanhToan" class="form-control" required>
                                    <option value="">-- Chọn --</option>
                                    <option value="Chuyển khoản">Chuyển khoản</option>
                                    <option value="Tiền mặt">Tiền mặt</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Ghi chú</label>
                                <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Nhập ghi chú nếu có..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn-premium btn-premium-solid" style="flex: 1; justify-content: center; padding: 0.7rem;">
                                <i class="fas fa-check"></i> Xác nhận đặt cọc (@Model.CartItems.Count xe)
                            </button>
                            <a asp-page="/Orders/Cart/Index" class="btn-premium btn-premium-outline" style="flex: 0 0 auto; padding: 0.7rem 1.5rem;">
                                Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
